# #####
# Dimensions
# #####

.h-0 {height: 0;}
.w-0 {width: 0;}
.h-1 {height: 1;}
.w-1 {width: 1;}
.h-2 {height: 2;}
.w-2 {width: 2;}
.h-3 {height: 3;}
.w-3 {width: 3;}
.h-4 {height: 4;}
.w-4 {width: 4;}
.h-5 {height: 5;}
.w-5 {width: 5;}
.w-auto {width: auto;}
.h-auto {height: auto;}
.w-full {width: 100%;}
.h-full {height: 100%;}

# #####
# Text Colors
# #####

.text-primary {color: $text-primary;}
.text-secondary {color: $text-secondary;}
.text-accent {color: $text-accent;}

# #####
# Backgrounds
# #####

.bg-primary {background: $primary;}
.bg-secondary {background: $secondary;}
.bg-accent {background: $accent;}
.bg-background {background: $background;}

