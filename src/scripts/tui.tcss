.border-t-tall-accent {border-top: tall $accent;}
.border-b-tall-accent {border-bottom: tall $accent;}
.border-x-tall-accent {border-left: tall $accent; border-right: tall $accent;}
.border-y-tall-accent {border-top: tall $accent; border-bottom: tall $accent;}
.border-vkey-accent {border: vkey $accent;}
.border-l-vkey-accent {border-left: vkey $accent;}
.border-r-vkey-accent {border-right: vkey $accent;}
.border-t-vkey-accent {border-top: vkey $accent;}
.border-b-vkey-accent {border-bottom: vkey $accent;}
.border-x-vkey-accent {border-left: vkey $accent; border-right: vkey $accent;}
.border-y-vkey-accent {border-top: vkey $accent; border-bottom: vkey $accent;}
.border-wide-accent {border: wide $accent;}
.border-l-wide-accent {border-left: wide $accent;}
.border-r-wide-accent {border-right: wide $accent;}
.border-t-wide-accent {border-top: wide $accent;}
.border-b-wide-accent {border-bottom: wide $accent;}
.border-x-wide-accent {border-left: wide $accent; border-right: wide $accent;}
.border-y-wide-accent {border-top: wide $accent; border-bottom: wide $accent;}

# #####
# Dock
# #####

.dock-top {dock: top;}
.dock-right {dock: right;}
.dock-bottom {dock: bottom;}
.dock-left {dock: left;}

# #####
# Visibility
# #####

.visible {visibility: visible;}
.hidden {visibility: hidden;}

# #####
# Text Styles
# #####

.bold {text-style: bold;}
.italic {text-style: italic;}
.reverse {text-style: reverse;}
.underline {text-style: underline;}
.strike {text-style: strike;}
