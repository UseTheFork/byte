.mt-5 {margin-top: 5;}
.mb-5 {margin-bottom: 5;}
.ml-5 {margin-left: 5;}
.mr-5 {margin-right: 5;}

# #####
# Padding
# #####

.p-0 {padding: 0;}
.px-0 {padding-left: 0; padding-right: 0;}
.py-0 {padding-top: 0; padding-bottom: 0;}
.pt-0 {padding-top: 0;}
.pb-0 {padding-bottom: 0;}
.pl-0 {padding-left: 0;}
.pr-0 {padding-right: 0;}
.p-1 {padding: 1;}
.px-1 {padding-left: 1; padding-right: 1;}
.py-1 {padding-top: 1; padding-bottom: 1;}
.pt-1 {padding-top: 1;}
.pb-1 {padding-bottom: 1;}
.pl-1 {padding-left: 1;}
.pr-1 {padding-right: 1;}
.p-2 {padding: 2;}
.px-2 {padding-left: 2; padding-right: 2;}
.py-2 {padding-top: 2; padding-bottom: 2;}
.pt-2 {padding-top: 2;}
.pb-2 {padding-bottom: 2;}
.pl-2 {padding-left: 2;}
.pr-2 {padding-right: 2;}
.p-3 {padding: 3;}
.px-3 {padding-left: 3; padding-right: 3;}
.py-3 {padding-top: 3; padding-bottom: 3;}
.pt-3 {padding-top: 3;}
.pb-3 {padding-bottom: 3;}
.pl-3 {padding-left: 3;}
.pr-3 {padding-right: 3;}
.p-4 {padding: 4;}
.px-4 {padding-left: 4; padding-right: 4;}
.py-4 {padding-top: 4; padding-bottom: 4;}
.pt-4 {padding-top: 4;}
.pb-4 {padding-bottom: 4;}
.pl-4 {padding-left: 4;}
.pr-4 {padding-right: 4;}
.p-5 {padding: 5;}
.px-5 {padding-left: 5; padding-right: 5;}
