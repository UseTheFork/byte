.pt-5 {padding-top: 5;}
.pb-5 {padding-bottom: 5;}
.pl-5 {padding-left: 5;}
.pr-5 {padding-right: 5;}


.layout-horizontal {layout: horizontal;}
.layout-vertical {layout: vertical;}

.overflow-hidden {overflow: hidden hidden;}

