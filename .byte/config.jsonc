{
  "$schema": "https://raw.githubusercontent.com/UseTheFork/byte/refs/heads/development/schema.json",
  "llm": {
    "reasoning": {
      "model": "claude-opus-4-6",
      "provider": "anthropic"
    },
    "standard": {
      "model": "claude-sonnet-4-6",
      "provider": "anthropic"
    },
    "coding": {
      "model": "claude-haiku-4-5",
      "provider": "anthropic"
    },
    "fast": {
      "model": "claude-haiku-4-5",
      "provider": "anthropic"
    }
  },
  "gateway": {
    "enable": true
  },
  "lint": {
    "enable": true,
    "commands": [
      {
        "command": ["uv", "run", "ssort"],
        "languages": ["python"]
      },
      {
        "command": ["uv", "run", "ruff", "format", "--force-exclude", "--respect-gitignore"],
        "languages": ["python"]
      },
      {
        "command": ["uv", "run", "ruff", "check", "--fix", "--force-exclude"],
        "languages": ["python"]
      },
      {
        "command": ["prettier", "--write"],
        "languages": ["markdown"]
      },
      {
        "command": ["keep-sorted"],
        "languages": ["*"]
      }
    ]
  },
  "files": {
    "ignore": [".byte/cache", ".ruff_cache", ".idea", ".venv", ".env", ".git", ".pytest_cache", "__pycache__", "node_modules"],
    "watch": {
      "enable": true
    }
  },
  "tui": {
    "ui_theme": "mocha",
    "syntax_theme": "github-dark"
  },
  "lsp": {
    "enable": false,
    "timeout": 30,
    "servers": {
      "python": {
        "preset": "ty",
        "server_type": "local",
        "languages": ["python"]
      }
    }
  }
}
