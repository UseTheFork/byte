{
  "printWidth": 150,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": true,
  "trailingComma": "es5",
  "bracketSpacing": true,
  "arrowParens": "always",
  "endOfLine": "lf",
  "proseWrap": "preserve",
    "overrides": [
    {
        "files": ["*.json", "*.jsonc"],
        "options": {
            "trailingComma": "none"
        }
    }
    ]
}
